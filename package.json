{
  "name": "saas-management-core",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "test": "npm run reset-db && jest --runInBand --verbose",
    "db:migrate": "sequelize-cli db:migrate --require ts-node/register",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --require ts-node/register",
    "db:seed": "sequelize-cli db:seed:all --require ts-node/register",
    "db:seed:undo": "sequelize-cli db:seed:undo:all --require ts-node/register",
    "migrate": "npm run build && env $(cat .env) npx sequelize-cli db:create && env $(cat .env) npx sequelize db:migrate",
    "reset-db": "npm run build && npx sequelize-cli db:drop && npx sequelize-cli db:create && npm run migrate",
    "lint": "eslint . --ext .ts --fix"
  },
  "dependencies": {
    "@joi/date": "^2.1.1",
    "argon2": "^0.43.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.5.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sequelize": "^6.36.1",
    "sequelize-typescript": "^2.1.6",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/argon2": "^0.14.1",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/hapi__joi": "^17.1.15",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1"
  }
}
