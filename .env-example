# ======================================
# Ambiente
# NODE_ENV: development | production | test
NODE_ENV=development
PORT=3001

# ======================================
# Configuração do MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_USER_PASSWORD=changeme          # Substitua pela sua senha real
MYSQL_DATABASE_NAME=saas_management_core
MYSQL_WAIT_FOR_CONNECTIONS=true
MYSQL_CONNECTION_LIMIT=10
MYSQL_QUEUE_LIMIT=0
DB_DIALECT=mysql

# ======================================
# Conta de Admin padrão (apenas dev/test)
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=admin123               # Substitua em produção

# ======================================
# JWT
JWT_SECRET=changeme                   # Substitua por uma chave secreta segura